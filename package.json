{
  "name": "sagui-actions",
  "version": "0.0.0",
  "private": true,
  "description": "Shared GitHub Actions monorepo",
  "scripts": {
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset tag",
    "lint": "eslint 'packages/**/*.{ts,js,sh,yml,yaml}'",
    "lint:fix": "eslint 'packages/**/*.{ts,js,sh,yml,yaml}' --fix",
    "validate": "pnpm lint && pnpm -r run validate",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-yml": "^1.19.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}
